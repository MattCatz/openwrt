In user namespace environments (like Nix buildFHSEnv), chown operations
on unmapped UIDs return EINVAL instead of EPERM. This causes fakeroot
to fail even though it correctly records the fake ownership.

Treat EINVAL the same as EPERM by suppressing the error and returning
success. The fake ownership is already recorded in the faked daemon.

See: https://bugs.debian.org/cgi-bin/bugreport.cgi?bug=802612
See: https://github.com/NixOS/nixpkgs/issues/10496

--- a/libfakeroot.c
+++ b/libfakeroot.c
@@ -861,7 +861,7 @@ int chown(const char *path, uid_t owner,
     r=next_lchown(path,owner,group);
   else
     r=0;
-  if(r&&(errno==EPERM))
+  if(r&&(errno==EPERM||errno==EINVAL))
     r=0;

   return r;
@@ -888,7 +888,7 @@ int lchown(const char *path, uid_t owner
     r=next_lchown(path,owner,group);
   else
     r=0;
-  if(r&&(errno==EPERM))
+  if(r&&(errno==EPERM||errno==EINVAL))
     r=0;

   return r;
@@ -912,7 +912,7 @@ int fchown(int fd, uid_t owner, gid_t gr
   else
     r=0;

-  if(r&&(errno==EPERM))
+  if(r&&(errno==EPERM||errno==EINVAL))
     r=0;

   return r;
@@ -939,7 +939,7 @@ int fchownat(int dir_fd, const char *pat
   else
     r=0;

-  if(r&&(errno==EPERM))
+  if(r&&(errno==EPERM||errno==EINVAL))
     r=0;

   return r;
